{
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=/Users/yao/work/code/personal/Claude-Code-Voice-Buddy python3 -m voice_buddy",
            "timeout": 5000,
            "async": true
          }
        ],
        "_voice_buddy": true
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=/Users/yao/work/code/personal/Claude-Code-Voice-Buddy python3 -m voice_buddy",
            "timeout": 5000,
            "async": true
          }
        ],
        "_voice_buddy": true
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=/Users/yao/work/code/personal/Claude-Code-Voice-Buddy python3 -m voice_buddy",
            "timeout": 5000,
            "async": true
          }
        ],
        "_voice_buddy": true,
        "matcher": "Bash"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=/Users/yao/work/code/personal/Claude-Code-Voice-Buddy python3 -m voice_buddy",
            "timeout": 5000,
            "async": true
          }
        ],
        "_voice_buddy": true
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=/Users/yao/work/code/personal/Claude-Code-Voice-Buddy python3 -m voice_buddy",
            "timeout": 5000,
            "async": true
          }
        ],
        "_voice_buddy": true
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=/Users/yao/work/code/personal/Claude-Code-Voice-Buddy python3 -m voice_buddy",
            "timeout": 5000,
            "async": false
          }
        ],
        "_voice_buddy": true
      }
    ]
  }
}